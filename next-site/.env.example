# Base URL of the WordPress install (no trailing slash).
WP_API_URL=https://old.taylorchasewhite.com/wp-json/wp/v2

# Public site URL (used for metadata / canonical URLs).
NEXT_PUBLIC_SITE_URL=https://taylorchasewhite.com

# WordPress application password credentials. Required to read protected
# endpoints like /pages/{id}/revisions (used by the About page timeline
# to surface the live edit history). Create one in WP Admin under
# Users -> Profile -> Application Passwords.
WP_AUTH_USER=
WP_AUTH_APP_PASSWORD=
